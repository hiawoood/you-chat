# Required
BETTER_AUTH_SECRET=change-me-to-a-random-string

# Optional
PORT=8080
ADMIN_EMAIL=admin@local.dev
ADMIN_PASSWORD=change-me
# DATABASE_DIR=/data

# Vast.ai TTS Integration (Optional - for GPU TTS)
# Get your API key from: https://cloud.vast.ai/account/
VAST_API_KEY=your_vast_api_key_here
# Get your token from: https://huggingface.co/settings/tokens
# Required for downloading the Chatterbox Turbo model
HF_TOKEN=your_huggingface_token_here
